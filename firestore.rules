rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - role: string (optional) - 'admin'
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - name: string
    //   - description: string (optional)
    //   - price: number
    //   - promotionalPrice: number (optional)
    //   - category: string
    //   - image: string
    //   - badge: string (optional)
    //   - popular: boolean (optional)
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - customerName: string
    //   - customerPhone: string
    //   - mode: string ('retirada', 'entrega')
    //   - address: string (optional)
    //   - date: string (optional)
    //   - payment: string ('Pix', 'Cartão', 'Dinheiro')
    //   - total: number
    //   - status: string
    //   - createdAt: timestamp
    //   - coupon: string (optional)
    //   - items: list of objects
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email == 'gustavomedeirosg12@gmail.com' && request.auth.token.email_verified == true) ||
        (request.auth.token.email == 'Jokaacunha05@gmail.com' && request.auth.token.email_verified == true) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function isValidProduct(data) {
      return hasRequiredFields(['name', 'price', 'category', 'image']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string && data.category.size() > 0 && data.category.size() < 50 &&
             data.image is string && data.image.size() > 0 && data.image.size() < 1048576 && // Allow large base64 images up to ~1MB
             (!('description' in data) || (data.description is string && data.description.size() < 1000)) &&
             (!('promotionalPrice' in data) || (data.promotionalPrice is number && data.promotionalPrice >= 0)) &&
             (!('badge' in data) || (data.badge is string && data.badge.size() < 50)) &&
             (!('popular' in data) || data.popular is bool) &&
             (!('isVisible' in data) || data.isVisible is bool);
    }

    function isValidOrder(data) {
      return hasRequiredFields(['customerName', 'customerPhone', 'mode', 'payment', 'total', 'status', 'createdAt', 'items']) &&
             data.customerName is string && data.customerName.size() > 0 && data.customerName.size() < 100 &&
             data.customerPhone is string && data.customerPhone.size() > 0 && data.customerPhone.size() < 30 &&
             data.mode in ['retirada', 'entrega'] &&
             data.payment in ['Pix', 'Cartão', 'Dinheiro'] &&
             data.total is number && data.total >= 0 &&
             data.status is string && data.status.size() > 0 && data.status.size() < 50 &&
             data.createdAt is timestamp &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             (!('address' in data) || (data.address is string && data.address.size() < 500)) &&
             (!('date' in data) || (data.date is string && data.date.size() < 30)) &&
             (!('coupon' in data) || (data.coupon is string && data.coupon.size() < 50));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /test/{docId} {
      allow read: if true;
    }

    match /users/{userId} {
      // Users can read their own profile. Admins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Only admins can create/update roles.
      allow create, update: if isAdmin() && 
                            (!('role' in request.resource.data) || request.resource.data.role in ['admin', 'user']);
      
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      // Anyone can read the catalog
      allow read: if true;
      
      // Only admins can manage the catalog
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Anyone can create an order (no auth required for checkout)
      allow create: if isValidOrder(request.resource.data);
      
      // Only admins can read, update, or delete orders
      allow read: if isAdmin();
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
